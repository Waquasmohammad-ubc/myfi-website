---
const title = "MyFi | Coming Soon";
const description = "MyFi is launching soon. Your AI-powered personal finance assistant for Canadians is almost ready.";
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="description" content={description}>
  <title>{title}</title>
  <link rel="icon" type="image/png" href="/logo.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
</head>
<body>
  <div class="page-bg">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
    <div class="grid-pattern"></div>
  </div>

  <!-- Home button top-left -->
  <a href="/" class="home-btn" title="Back to Home">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
      <polyline points="9 22 9 12 15 12 15 22"/>
    </svg>
  </a>

  <div class="page">
    <!-- Logo -->
    <a href="/" class="logo">
      <img src="/logo.png" alt="MyFi" />
    </a>

    <!-- Chat Window (wide browser style) -->
    <div class="chat-window">
      <div class="chat-header">
        <div class="chat-dots">
          <span class="dot red"></span>
          <span class="dot yellow"></span>
          <span class="dot green"></span>
        </div>
        <div class="chat-url-bar">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
          <span>app.my-fi.ca</span>
        </div>
        <div class="chat-header-right">
          <div class="status-dot"></div>
          <span>MyFi Assistant</span>
        </div>
      </div>

      <div class="chat-body" id="chatBody">
        <!-- Message 1: Bot greeting -->
        <div class="msg msg-bot msg-1">
          <div class="msg-avatar">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
            </svg>
          </div>
          <div class="msg-bubble bot-bubble">Hey there! Welcome to MyFi.</div>
        </div>

        <!-- Message 2: User -->
        <div class="msg msg-user msg-2">
          <div class="msg-bubble user-bubble">I'd like to start planning my finances!</div>
        </div>

        <!-- Message 3: Bot -->
        <div class="msg msg-bot msg-3">
          <div class="msg-avatar">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
            </svg>
          </div>
          <div class="msg-bubble bot-bubble">I love the enthusiasm! We're putting the finishing touches on something special for you.</div>
        </div>

        <!-- Message 4: Coming soon card -->
        <div class="msg msg-bot msg-4">
          <div class="msg-avatar">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
            </svg>
          </div>
          <div class="msg-card">
            <div class="card-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <div class="card-title">Coming Soon</div>
            <div class="card-desc">Your AI-powered financial assistant is almost ready. We're building something truly personalized for Canadians.</div>
            <div class="card-features">
              <div class="card-feature">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Personalized financial planning</span>
              </div>
              <div class="card-feature">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Built for Canadian finances</span>
              </div>
              <div class="card-feature">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                <span>AI-powered insights & guidance</span>
              </div>
            </div>
            <div class="card-shimmer"></div>
          </div>
        </div>

        <!-- Message 5: Ask for email -->
        <div class="msg msg-bot msg-5">
          <div class="msg-avatar">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
            </svg>
          </div>
          <div class="msg-bubble bot-bubble">Drop your email below and I'll notify you the moment we launch!</div>
        </div>
      </div>

      <!-- Chat input (real email input) -->
      <form class="chat-input" id="emailForm">
        <input
          type="email"
          class="input-field"
          id="emailInput"
          placeholder="Enter your email to get notified..."
          required
          autocomplete="email"
        />
        <button type="submit" class="input-btn" id="sendBtn" title="Send">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="send-icon">
            <line x1="22" y1="2" x2="11" y2="13"/>
            <polygon points="22 2 15 22 11 13 2 9 22 2"/>
          </svg>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="loading-icon" style="display:none;">
            <circle cx="12" cy="12" r="10" stroke-dasharray="60" stroke-dashoffset="20"/>
          </svg>
        </button>
      </form>
    </div>
  </div>

  <script is:inline>
    // ── EmailJS Config ──
    // Replace these with your actual EmailJS credentials
    const EMAILJS_PUBLIC_KEY = 'OvRhVy-J_Pn2FWabj';
    const EMAILJS_SERVICE_ID = 'service_b5fzj8n';
    const EMAILJS_TEMPLATE_ID = 'template_am7bo9t';

    emailjs.init(EMAILJS_PUBLIC_KEY);

    const form = document.getElementById('emailForm');
    const emailInput = document.getElementById('emailInput');
    const sendBtn = document.getElementById('sendBtn');
    const chatBody = document.getElementById('chatBody');

    function createMsgAvatar() {
      const avatar = document.createElement('div');
      avatar.className = 'msg-avatar';
      avatar.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>';
      return avatar;
    }

    function addMessage(text, type, isCard) {
      const msg = document.createElement('div');
      msg.className = `msg msg-${type}`;
      msg.style.opacity = '0';
      msg.style.transform = 'translateY(12px)';

      if (type === 'bot') {
        msg.appendChild(createMsgAvatar());
      }

      if (isCard) {
        const card = document.createElement('div');
        card.className = 'success-card';
        card.innerHTML = text;
        msg.appendChild(card);
      } else {
        const bubble = document.createElement('div');
        bubble.className = `msg-bubble ${type === 'bot' ? 'bot-bubble' : 'user-bubble'}`;
        bubble.textContent = text;
        msg.appendChild(bubble);
      }

      chatBody.appendChild(msg);

      requestAnimationFrame(() => {
        msg.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
        msg.style.opacity = '1';
        msg.style.transform = 'translateY(0)';
      });

      chatBody.scrollTop = chatBody.scrollHeight;
    }

    function addTypingIndicator() {
      const typing = document.createElement('div');
      typing.className = 'msg msg-bot';
      typing.id = 'typingIndicator';
      typing.style.opacity = '0';
      typing.style.transform = 'translateY(12px)';

      typing.appendChild(createMsgAvatar());

      const dots = document.createElement('div');
      dots.className = 'typing-dots';
      dots.innerHTML = '<span></span><span></span><span></span>';
      typing.appendChild(dots);

      chatBody.appendChild(typing);
      requestAnimationFrame(() => {
        typing.style.transition = 'opacity 0.4s ease, transform 0.4s ease';
        typing.style.opacity = '1';
        typing.style.transform = 'translateY(0)';
      });

      chatBody.scrollTop = chatBody.scrollHeight;
    }

    function removeTypingIndicator() {
      const el = document.getElementById('typingIndicator');
      if (el) el.remove();
    }

    let submitted = false;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      if (submitted) return;

      const email = emailInput.value.trim();
      if (!email) return;

      submitted = true;

      // Show user's email as a message
      addMessage(email, 'user');
      emailInput.value = '';
      emailInput.disabled = true;
      sendBtn.disabled = true;
      sendBtn.querySelector('.send-icon').style.display = 'none';
      sendBtn.querySelector('.loading-icon').style.display = 'block';

      // Show typing
      setTimeout(() => addTypingIndicator(), 400);

      try {
        await emailjs.send(EMAILJS_SERVICE_ID, EMAILJS_TEMPLATE_ID, {
          user_email: email,
          to_email: email,
        });

        setTimeout(() => {
          removeTypingIndicator();
          addMessage(
            '<div class="sc-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg></div><div class="sc-title">You\'re on the list!</div><div class="sc-desc">We\'ll send you an email at <strong>' + email + '</strong> as soon as MyFi launches. Stay tuned!</div>',
            'bot',
            true
          );
        }, 1500);
      } catch (err) {
        setTimeout(() => {
          removeTypingIndicator();
          addMessage("Oops, something went wrong. Please try emailing us directly at connect@my-fi.ca", 'bot');
          emailInput.disabled = false;
          sendBtn.disabled = false;
          sendBtn.querySelector('.send-icon').style.display = 'block';
          sendBtn.querySelector('.loading-icon').style.display = 'none';
          submitted = false;
        }, 1500);
      }
    });
  </script>

  <style>
    :root {
      --white: #ffffff;
      --purple-50: #faf5ff;
      --purple-100: #f3e8ff;
      --purple-200: #e9d5ff;
      --purple-300: #d8b4fe;
      --purple-400: #c084fc;
      --purple-500: #a855f7;
      --purple-600: #9333ea;
      --purple-700: #7c3aed;
      --purple-800: #6b21a8;
      --green-100: #dcfce7;
      --green-200: #bbf7d0;
      --green-300: #86efac;
      --green-400: #4ade80;
      --green-500: #22c55e;
      --green-600: #16a34a;
      --gray-50: #fafafa;
      --gray-100: #f5f5f5;
      --gray-200: #e5e5e5;
      --gray-300: #d4d4d4;
      --gray-400: #a3a3a3;
      --gray-500: #737373;
      --gray-600: #525252;
      --gray-700: #404040;
      --gray-800: #262626;
      --gray-900: #171717;
      --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { -webkit-font-smoothing: antialiased; }

    body {
      font-family: var(--font-sans);
      font-size: 1rem;
      line-height: 1.7;
      color: var(--gray-700);
      background: var(--white);
      min-height: 100vh;
      overflow-x: hidden;
    }

    a { color: inherit; text-decoration: none; }
    button { font-family: var(--font-sans); }

    /* Background */
    .page-bg {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      overflow: hidden;
    }

    .blob {
      position: absolute;
      border-radius: 50%;
      filter: blur(80px);
    }

    .blob-1 {
      width: 600px; height: 600px;
      background: var(--purple-200);
      top: -200px; right: -150px;
      opacity: 0.45;
      animation: float 14s ease-in-out infinite;
    }

    .blob-2 {
      width: 400px; height: 400px;
      background: var(--green-200);
      bottom: -100px; left: -100px;
      opacity: 0.35;
      animation: float 18s ease-in-out infinite reverse;
    }

    .blob-3 {
      width: 250px; height: 250px;
      background: var(--purple-300);
      top: 40%; left: 20%;
      opacity: 0.2;
      animation: float 11s ease-in-out infinite;
    }

    .grid-pattern {
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(147, 51, 234, 0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(147, 51, 234, 0.03) 1px, transparent 1px);
      background-size: 60px 60px;
    }

    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-20px); }
    }

    /* Home Button */
    .home-btn {
      position: fixed;
      top: 1.25rem;
      left: 1.25rem;
      z-index: 10;
      width: 44px;
      height: 44px;
      background: var(--white);
      border: 1px solid var(--gray-200);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--gray-600);
      transition: all 0.2s ease;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
      opacity: 0;
      animation: fadeIn 0.5s ease forwards 0.1s;
    }

    .home-btn:hover {
      color: var(--purple-600);
      border-color: var(--purple-300);
      transform: translateY(-1px);
      box-shadow: 0 4px 12px rgba(147, 51, 234, 0.12);
    }

    @media (max-width: 600px) {
      .home-btn {
        top: 0.75rem;
        left: 0.75rem;
        width: 40px;
        height: 40px;
        border-radius: 10px;
      }
    }

    /* Page Layout */
    .page {
      position: relative;
      z-index: 1;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 2rem 1.5rem;
      gap: 1.5rem;
    }

    @media (max-width: 600px) {
      .page {
        padding: 1rem 0.75rem;
        gap: 1rem;
        justify-content: flex-start;
        padding-top: 4rem;
      }
    }

    /* Logo */
    .logo {
      opacity: 0;
      animation: fadeIn 0.6s ease forwards;
    }

    .logo img {
      height: 56px;
      width: auto;
    }

    @media (max-width: 600px) {
      .logo img {
        height: 48px;
      }
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(-10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* Chat Window - Wide browser style */
    .chat-window {
      width: 100%;
      max-width: 860px;
      background: var(--white);
      border-radius: 16px;
      box-shadow:
        0 0 0 1px rgba(0, 0, 0, 0.04),
        0 25px 60px rgba(147, 51, 234, 0.15),
        0 4px 20px rgba(0, 0, 0, 0.06);
      overflow: hidden;
      opacity: 0;
      animation: windowAppear 0.7s ease forwards 0.2s;
    }

    @media (max-width: 600px) {
      .chat-window {
        border-radius: 0;
        box-shadow: none;
        flex: 1;
        display: flex;
        flex-direction: column;
        min-height: 0;
      }
    }

    @keyframes windowAppear {
      from { opacity: 0; transform: translateY(30px) scale(0.97); }
      to { opacity: 1; transform: translateY(0) scale(1); }
    }

    /* Browser-style header */
    .chat-header {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 0.75rem 1.25rem;
      background: var(--gray-50);
      border-bottom: 1px solid var(--gray-100);
    }

    @media (max-width: 600px) {
      .chat-header {
        padding: 0.625rem 1rem;
        gap: 0.625rem;
      }
    }

    .chat-dots {
      display: flex;
      gap: 6px;
      flex-shrink: 0;
    }

    @media (max-width: 600px) {
      .chat-dots { display: none; }
    }

    .dot { width: 10px; height: 10px; border-radius: 50%; }
    .dot.red { background: #ff5f57; }
    .dot.yellow { background: #ffbd2e; }
    .dot.green { background: #28c840; }

    .chat-url-bar {
      flex: 1;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--white);
      border: 1px solid var(--gray-200);
      border-radius: 8px;
      padding: 0.375rem 0.75rem;
      font-size: 0.75rem;
      color: var(--gray-500);
      max-width: 320px;
    }

    .chat-url-bar svg { color: var(--green-500); flex-shrink: 0; }

    .chat-header-right {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.8125rem;
      font-weight: 600;
      color: var(--gray-800);
      margin-left: auto;
      flex-shrink: 0;
    }

    @media (max-width: 600px) {
      .chat-header-right {
        margin-left: 0;
      }
    }

    .status-dot {
      width: 8px; height: 8px;
      background: var(--green-500);
      border-radius: 50%;
      animation: pulse 2s ease-in-out infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(1.4); }
    }

    /* Chat Body */
    .chat-body {
      padding: 1.5rem 2rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      min-height: 400px;
      max-height: 520px;
      overflow-y: auto;
    }

    @media (max-width: 600px) {
      .chat-body {
        padding: 1rem;
        min-height: 0;
        max-height: none;
        flex: 1;
        gap: 0.75rem;
      }
    }

    /* Scrollbar */
    .chat-body::-webkit-scrollbar { width: 4px; }
    .chat-body::-webkit-scrollbar-track { background: transparent; }
    .chat-body::-webkit-scrollbar-thumb { background: var(--gray-300); border-radius: 4px; }

    /* Messages */
    .msg {
      display: flex;
      gap: 0.625rem;
      align-items: flex-end;
      opacity: 0;
      transform: translateY(12px);
    }

    .msg-bot { justify-content: flex-start; }
    .msg-user { justify-content: flex-end; }

    .msg-1 { animation: msgSlideIn 0.5s ease forwards 0.6s; }
    .msg-2 { animation: msgSlideIn 0.5s ease forwards 1.6s; }
    .msg-3 { animation: msgSlideIn 0.5s ease forwards 2.8s; }
    .msg-4 { animation: msgSlideIn 0.6s ease forwards 4.0s; }
    .msg-5 { animation: msgSlideIn 0.5s ease forwards 5.6s; }

    @keyframes msgSlideIn {
      from { opacity: 0; transform: translateY(12px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .msg-avatar {
      width: 32px; height: 32px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--purple-100), var(--purple-200));
      color: var(--purple-600);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    @media (max-width: 600px) {
      .msg-avatar {
        width: 28px; height: 28px;
      }
      .msg-avatar svg {
        width: 14px; height: 14px;
      }
    }

    .msg-bubble {
      max-width: 65%;
      padding: 0.75rem 1rem;
      border-radius: 16px;
      font-size: 0.9rem;
      line-height: 1.55;
    }

    @media (max-width: 600px) {
      .msg-bubble {
        max-width: 82%;
        padding: 0.625rem 0.875rem;
        font-size: 0.8125rem;
        border-radius: 14px;
      }
    }

    .bot-bubble {
      background: var(--gray-100);
      color: var(--gray-800);
      border-bottom-left-radius: 4px;
    }

    .user-bubble {
      background: linear-gradient(135deg, var(--purple-600), var(--purple-700));
      color: var(--white);
      border-bottom-right-radius: 4px;
    }

    /* Coming Soon Card */
    .msg-card {
      background: var(--white);
      border: 1px solid var(--gray-200);
      border-radius: 16px;
      padding: 1.25rem 1.5rem;
      max-width: 65%;
      position: relative;
      overflow: hidden;
    }

    @media (max-width: 600px) {
      .msg-card {
        max-width: 88%;
        padding: 1rem 1.125rem;
        border-radius: 14px;
      }
    }

    .card-icon {
      width: 48px; height: 48px;
      background: linear-gradient(135deg, var(--purple-500), var(--green-500));
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--white);
      margin-bottom: 0.75rem;
      animation: iconPulse 3s ease-in-out infinite;
      animation-delay: 4.5s;
    }

    @media (max-width: 600px) {
      .card-icon {
        width: 40px; height: 40px;
        border-radius: 12px;
        margin-bottom: 0.625rem;
      }
      .card-icon svg { width: 22px; height: 22px; }
    }

    @keyframes iconPulse {
      0%, 100% { box-shadow: 0 4px 15px rgba(147, 51, 234, 0.2); }
      50% { box-shadow: 0 4px 25px rgba(147, 51, 234, 0.4), 0 0 0 6px rgba(147, 51, 234, 0.08); }
    }

    .card-title {
      font-size: 1.25rem;
      font-weight: 700;
      background: linear-gradient(135deg, var(--purple-700), var(--green-600));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 0.375rem;
    }

    @media (max-width: 600px) {
      .card-title { font-size: 1.0625rem; }
    }

    .card-desc {
      font-size: 0.8125rem;
      color: var(--gray-500);
      line-height: 1.6;
      margin-bottom: 1rem;
    }

    @media (max-width: 600px) {
      .card-desc {
        font-size: 0.75rem;
        margin-bottom: 0.75rem;
      }
    }

    .card-features {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    @media (max-width: 600px) {
      .card-features { gap: 0.375rem; }
    }

    .card-feature {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.8125rem;
      font-weight: 500;
      color: var(--gray-700);
    }

    @media (max-width: 600px) {
      .card-feature {
        font-size: 0.75rem;
        gap: 0.375rem;
      }
      .card-feature svg { width: 12px; height: 12px; }
    }

    .card-feature svg { color: var(--green-500); flex-shrink: 0; }

    .card-shimmer {
      position: absolute;
      top: 0; left: -100%;
      width: 100%; height: 100%;
      background: linear-gradient(90deg, transparent, rgba(147, 51, 234, 0.04), transparent);
      animation: shimmer 3s ease-in-out infinite;
      animation-delay: 5s;
    }

    @keyframes shimmer {
      0% { left: -100%; }
      100% { left: 100%; }
    }

    /* Typing Dots */
    .typing-dots {
      display: flex;
      gap: 5px;
      padding: 0.75rem 1rem;
      background: var(--gray-100);
      border-radius: 16px;
      border-bottom-left-radius: 4px;
    }

    .typing-dots span {
      width: 7px; height: 7px;
      background: var(--gray-400);
      border-radius: 50%;
      animation: typingBounce 1.4s ease-in-out infinite;
    }

    .typing-dots span:nth-child(2) { animation-delay: 0.2s; }
    .typing-dots span:nth-child(3) { animation-delay: 0.4s; }

    @keyframes typingBounce {
      0%, 60%, 100% { opacity: 0.3; transform: translateY(0); }
      30% { opacity: 1; transform: translateY(-5px); }
    }

    /* Success Card */
    .success-card {
      background: linear-gradient(135deg, var(--purple-50), var(--green-100));
      border: 1px solid var(--green-200);
      border-radius: 16px;
      padding: 1.25rem 1.5rem;
      max-width: 65%;
    }

    @media (max-width: 600px) {
      .success-card {
        max-width: 88%;
        padding: 1rem 1.125rem;
        border-radius: 14px;
      }
    }

    .sc-icon {
      width: 44px; height: 44px;
      background: var(--green-500);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--white);
      margin-bottom: 0.75rem;
      animation: successPop 0.5s ease;
    }

    @media (max-width: 600px) {
      .sc-icon {
        width: 38px; height: 38px;
        margin-bottom: 0.625rem;
      }
      .sc-icon svg { width: 20px; height: 20px; }
    }

    @keyframes successPop {
      0% { transform: scale(0); }
      70% { transform: scale(1.15); }
      100% { transform: scale(1); }
    }

    .sc-title {
      font-size: 1.0625rem;
      font-weight: 700;
      color: var(--gray-900);
      margin-bottom: 0.25rem;
    }

    @media (max-width: 600px) {
      .sc-title { font-size: 0.9375rem; }
    }

    .sc-desc {
      font-size: 0.8125rem;
      color: var(--gray-600);
      line-height: 1.6;
    }

    @media (max-width: 600px) {
      .sc-desc { font-size: 0.75rem; }
    }

    .sc-desc strong {
      color: var(--purple-600);
    }

    /* Chat Input */
    .chat-input {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 1rem 2rem;
      border-top: 1px solid var(--gray-100);
      background: var(--gray-50);
    }

    @media (max-width: 600px) {
      .chat-input {
        padding: 0.75rem 1rem;
        gap: 0.5rem;
        /* Safe area for phones with home indicator */
        padding-bottom: calc(0.75rem + env(safe-area-inset-bottom, 0px));
      }
    }

    .input-field {
      flex: 1;
      padding: 0.75rem 1rem;
      background: var(--white);
      border: 1px solid var(--gray-200);
      border-radius: 12px;
      font-size: 0.9rem;
      font-family: var(--font-sans);
      color: var(--gray-800);
      outline: none;
      transition: border-color 0.2s ease;
      /* Prevent iOS zoom on focus */
      -webkit-appearance: none;
    }

    .input-field::placeholder { color: var(--gray-400); }

    .input-field:focus {
      border-color: var(--purple-400);
      box-shadow: 0 0 0 3px rgba(147, 51, 234, 0.08);
    }

    .input-field:disabled {
      background: var(--gray-100);
      color: var(--gray-400);
    }

    @media (max-width: 600px) {
      .input-field {
        padding: 0.75rem 0.875rem;
        font-size: 1rem;
        border-radius: 10px;
      }
    }

    .input-btn {
      width: 42px; height: 42px;
      background: linear-gradient(135deg, var(--purple-500), var(--purple-600));
      border-radius: 12px;
      border: none;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--white);
      cursor: pointer;
      transition: all 0.2s ease;
      flex-shrink: 0;
      /* Minimum touch target */
      min-width: 44px;
      min-height: 44px;
    }

    .input-btn:hover {
      transform: translateY(-1px);
      box-shadow: 0 4px 12px rgba(147, 51, 234, 0.3);
    }

    .input-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
      transform: none;
      box-shadow: none;
    }

    .loading-icon {
      animation: spin 1s linear infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    /* Responsive */
    @media (max-width: 600px) {
      .chat-url-bar { display: none; }
      .chat-header-right span { display: none; }

      .blob-1 { width: 300px; height: 300px; }
      .blob-2 { width: 200px; height: 200px; }
      .blob-3 { width: 150px; height: 150px; }
    }

    /* Fix for mobile vh with address bar */
    @supports (min-height: 100dvh) {
      body { min-height: 100dvh; }
      .page { min-height: 100dvh; }
    }
  </style>
</body>
</html>
